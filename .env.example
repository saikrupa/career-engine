# career-engine — Environment Variables
# Copy this file to .env and fill in your values, or run `npm run setup`.
#
#   cp .env.example .env
#
# Never commit .env.

# ── Gemini Integration ──────────────────────────────────────────────────────
# Required for: node gemini-eval.mjs "JD text here"
# Free API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the default Gemini model.
# GEMINI_MODEL=gemini-2.0-flash

# ── Portal Browser Sessions ─────────────────────────────────────────────────
# Optional. Prefer `npm run portal:login -- linkedin` for local browser storage.
# If you export Playwright storage state, keep it in .auth/ or storage/.
LINKEDIN_STORAGE_STATE=

# ── Job Alert Notifications ─────────────────────────────────────────────────
# Optional. Used by:
#   npm run notify:test
#   npm run portal:capture -- linkedin --url "..."
#   npm run alert:once
#   npm run alert:run
#
# Slack: use webhook for message-only alerts, or bot token + channel ID for file uploads.
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Telegram alerts and PDF delivery.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Other integrations ──────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
