# Personal data (user fills these)
cv.md
data/applications.md
data/pipeline.md
data/scan-history.tsv
reports/*.md
!reports/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/**/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# Writing samples (user's personal files — never committed)
writing-samples/*
!writing-samples/README.md

# User config and customization (never auto-updated)
config/profile.yml
config/job-alerts.yml
portals.yml
modes/_profile.md
.update-dismissed
.update-lock

# Secrets (never commit — use .env.example as template)
.env

# Local browser sessions for assistive portal capture/apply flows
.browser-profiles/
.auth/
storage/

# Generated
.resolved-prompt-*
node_modules/
bun.lock

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
career-engine-dashboard
package-lock.json
